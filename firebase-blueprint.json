{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "monthlyBudget": { "type": "number" },
        "cashInHand": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "paymentMethod": { "type": "string" },
        "accountId": { "type": "string" },
        "isSpend": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "category", "description", "date", "type"]
    },
    "Account": {
      "title": "Account",
      "description": "Financial account details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["bank", "credit_card"] },
        "number": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "isEstimated": { "type": "boolean" }
      },
      "required": ["name", "amount", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transactions"
    },
    "/users/{userId}/accounts/{accountId}": {
      "schema": "Account",
      "description": "User accounts"
    }
  }
}
